FROM fedora:43

RUN dnf -y update && \
    dnf -y install git curl jq bash findutils procps-ng openssh-clients ca-certificates \
                   python3 python3-pip nodejs npm && \
    dnf clean all

# Utente non-root
RUN useradd -m -u 1000 -s /bin/bash dev
USER dev
WORKDIR /workspaces

ENV PATH="/home/dev/.local/bin:${PATH}"

#Install Claude Code
RUN curl -fsSL https://claude.ai/install.sh | bash

# (Opzionale) installa qui tool CLI che NON richiedono secrets
# Esempio: pip install --user ...

