FROM fedora:43

# Pacchetti base + Java dev
RUN dnf -y install \
      git \
      curl \
      jq \
      bash \
      findutils \
      procps-ng \
      openssh-clients \
      ca-certificates \
      python3 \
      python3-pip \
      nodejs \
      npm \
      java-21-openjdk-devel \
      maven \
      vim-minimal \
      nano \
      tar \
      gzip \
      pipx \
      uv \
    && dnf clean all

RUN npm install -g backlog.md

# Utente non-root
RUN useradd -m -u 1000 -s /bin/bash dev
USER dev
WORKDIR /workspaces

# PATH per install user-local
ENV PATH="/home/dev/.local/bin:${PATH}"

# Install Claude Code
RUN curl -fsSL https://claude.ai/install.sh -o /tmp/claude-install.sh \
    && bash /tmp/claude-install.sh \
    && rm -f /tmp/claude-install.sh

# Install SuperClaude (including relevant MCP servers)
RUN pipx install superclaude
RUN superclaude install
RUN superclaude mcp --servers sequential-thinking --servers context7 --servers serena --servers playwright
